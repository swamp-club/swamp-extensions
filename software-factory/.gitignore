# BEGIN swamp managed section - DO NOT EDIT

# Runtime data (not needed in version control)
.swamp/

# Local extension sources (developer-specific, not shared)
.swamp-sources.yaml

# Claude Code configuration (managed by swamp)
.claude/
# END swamp managed section

# The software-factory skill ships as part of this extension, so it must be
# tracked even though .claude/ is ignored above. We have to un-ignore each
# ancestor with single-level globs because git refuses to descend into an
# ignored parent directory.
!.claude/
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/software-factory/
